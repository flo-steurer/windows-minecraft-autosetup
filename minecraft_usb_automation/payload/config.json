{
  "setupVersion": "1",
  "windows": {
    "adminUserName": "SetupAdmin",
    "playerUserName": "Player",
    "targetUserSetupAccounts": [
      "Player"
    ]
  },
  "minecraft": {
    "profileName": "Forge 1.8.9 Modpack",
    "versionId": "1.8.9-forge1.8.9-11.15.1.2318-1.8.9",
    "javaArgs": "-Xmx2G -Xms1G",
    "copyAssets": true,
    "requireAssets": false
  },
  "launcher": {
    "preferOfflineInstaller": true,
    "wingetId": "Mojang.MinecraftLauncher"
  },
  "cleanup": {
    "enabled": true,
    "clearWindowsTemp": true,
    "clearCurrentUserTemp": true,
    "clearAllUserTemp": true,
    "emptyRecycleBin": true,
    "clearWindowsUpdateDownloadCache": true,
    "clearDeliveryOptimizationCache": true,
    "runComponentCleanup": false
  },
  "destructiveCleanup": {
    "enabled": false,
    "confirmation": "",
    "deleteExistingPlayerProfile": true,
    "deleteKnownUserDataFolders": false,
    "knownUserDataFolders": [
      "Desktop",
      "Documents",
      "Downloads",
      "Pictures",
      "Videos",
      "Music"
    ],
    "excludeUsers": [
      "Public",
      "Default",
      "Default User",
      "All Users"
    ]
  },
  "uninstall": {
    "enabled": false,
    "allowNonQuietUninstallStrings": false,
    "displayNamePatterns": [
      "*Minecraft Launcher*",
      "*Roblox*",
      "*Java 8*",
      "*Java(TM) 8*"
    ]
  },
  "extraApps": [
    {
      "name": "Java 8 Runtime",
      "enabled": true,
      "preferOfflineInstaller": true,
      "installerFolder": "payload\\installers\\java8",
      "installerPatterns": [
        "*java*8*.exe",
        "*jre*8*.exe",
        "*temurin*8*jre*.msi",
        "*temurin*8*jre*.exe"
      ],
      "detectRegistryNamePatterns": [
        "*Java 8*",
        "*Java(TM) 8*",
        "*Temurin*8*JRE*"
      ],
      "silentArgs": [
        [
          "/s"
        ],
        [
          "/quiet",
          "/norestart"
        ],
        [
          "/silent",
          "/norestart"
        ],
        [
          "/S"
        ]
      ],
      "wingetId": "EclipseAdoptium.Temurin.8.JRE"
    },
    {
      "name": "Roblox Studio",
      "enabled": true,
      "preferOfflineInstaller": true,
      "installerFolder": "payload\\installers\\roblox-studio",
      "installerPatterns": [
        "*RobloxStudio*.exe",
        "*Roblox*Studio*.exe"
      ],
      "detectRegistryNamePatterns": [
        "*Roblox Studio*"
      ],
      "silentArgs": [
        [
          "-install"
        ],
        [
          "/quiet",
          "/norestart"
        ],
        [
          "/silent",
          "/norestart"
        ],
        [
          "/S"
        ],
        []
      ],
      "wingetId": "Roblox.RobloxStudio"
    }
  ],
  "mods": [
    {
      "file": "ComputerCraft1.79.jar",
      "sha256": ""
    },
    {
      "file": "ComputerCraftEdu1.79.jar",
      "sha256": ""
    },
    {
      "file": "forgeessentials-1.8.9-1.8.5.103-client.jar",
      "sha256": ""
    },
    {
      "file": "jei_1.8.9-2.28.18.187.jar",
      "sha256": ""
    },
    {
      "file": "OptiFine_1.8.9_HD_U_M5.jar",
      "sha256": ""
    }
  ]
}
