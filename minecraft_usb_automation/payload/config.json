{
  "cleanup": {
    "clearWindowsTemp": true,
    "clearAllUserTemp": true,
    "emptyRecycleBin": true,
    "clearWindowsUpdateDownloadCache": true,
    "clearDeliveryOptimizationCache": true,
    "runComponentCleanup": false
  },
  "apps": {
    "minecraftLauncher": {
      "name": "Minecraft Launcher",
      "requiresElevation": false,
      "allowInteractiveInstaller": true,
      "preferOfflineInstaller": true,
      "installerFolder": "payload\\installers\\minecraft-launcher",
      "installerPatterns": [
        "*Minecraft*.msi",
        "*Minecraft*.exe"
      ],
      "detectRegistryNamePatterns": [
        "*Minecraft Launcher*"
      ],
      "detectStartAppPatterns": [
        "*Minecraft Launcher*",
        "Minecraft"
      ],
      "silentArgs": [
        [
          "/quiet",
          "/norestart"
        ],
        [
          "/silent",
          "/norestart"
        ],
        [
          "/S"
        ]
      ],
      "wingetId": "Mojang.MinecraftLauncher"
    },
    "java8": {
      "name": "Java 8 Runtime",
      "requiresElevation": true,
      "detectJava8": true,
      "preferOfflineInstaller": true,
      "installerFolder": "payload\\installers\\java8",
      "installerPatterns": [
        "*java*8*.exe",
        "*jre*8*.exe",
        "*temurin*8*jre*.msi",
        "*temurin*8*jre*.exe"
      ],
      "detectRegistryNamePatterns": [
        "*Java 8*",
        "*Java(TM) 8*",
        "*Temurin*8*JRE*",
        "*Temurin*JRE*8*"
      ],
      "silentArgs": [
        [
          "/s"
        ],
        [
          "/quiet",
          "/norestart"
        ],
        [
          "/silent",
          "/norestart"
        ],
        [
          "/S"
        ]
      ],
      "wingetId": "EclipseAdoptium.Temurin.8.JRE"
    },
    "robloxStudio": {
      "name": "Roblox Studio",
      "requiresElevation": false,
      "allowInteractiveInstaller": true,
      "preferOfflineInstaller": true,
      "installerFolder": "payload\\installers\\roblox-studio",
      "installerPatterns": [
        "*RobloxStudio*.exe",
        "*Roblox*Studio*.exe"
      ],
      "detectRegistryNamePatterns": [
        "*Roblox Studio*"
      ],
      "detectStartAppPatterns": [
        "*Roblox Studio*"
      ],
      "silentArgs": [
        [
          "-install"
        ]
      ],
      "wingetId": "Roblox.RobloxStudio"
    }
  }
}
